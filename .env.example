# Either token auth:
MOYSKLAD_TOKEN=your_moysklad_token

# Or login/password auth:
# MOYSKLAD_LOGIN=your_login
# MOYSKLAD_PASSWORD=your_password

MOYSKLAD_BASE_URL=https://api.moysklad.ru/api/remap/1.2
DATA_SOURCE=moysklad

# Async queue / MoySklad safety limits.
REPORT_WORKERS=1
MOYSKLAD_MAX_CONCURRENT_REQUESTS=2
MOYSKLAD_MIN_REQUEST_INTERVAL_SECONDS=0.25
MOYSKLAD_RETRY_ATTEMPTS=3
MOYSKLAD_RETRY_BASE_DELAY_SECONDS=1.0
REPORT_RESULT_TTL_SECONDS=3600

# Report header.
REPORT_TENANT=ИП Леонтьев Д.С,
REPORT_TRADE_NAME=5LB
REPORT_RENT_CONTRACT=№1276К-25-ДАК
REPORT_ROOM=A1-2
REPORT_TAX_SYSTEM=ОСНО  ;         УСНО ;     Патент
REPORT_FISCAL_OPERATOR=Эватор
